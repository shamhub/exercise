{
  "/api/v1/user/(?P<userId>[^/]+)": {
    "method": "POST",
    "filters": {
      "route": "(.params.userId | length) > 0",
      "query_params": ". | has(\"name\")",
      "headers": ".headers[\"Authorization\"] != null",
      "payload": ". | .age >= 18 and (.email | contains(\"@\"))"
    },
    "responses": {
        "template_file": "templates/success.html"
    }
  },
  "/api/v1/user/(?P<userId>[^/]+)/profile": {
    "method": "PATCH",
    "filters": {
      "route": "(.params.userId | length) > 0",
      "payload": "(.body.display_name | length) >= 3"
    },
    "responses": {
        "template_file":"templates/index.html"
    }
  },
  "/api/v2/user/(?P<userId>[^/]+)": {
    "method": "GET",
    "filters": {
      "route": "(.params.userId | length) > 0"
    },
    "responses": {
        "template_file":"templates/message.html"
    }
  }
}